PORT=8003

# Postgres connection string (dedicated database per microservice)
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/hdt_ai_agent

# Google Gemini API key (https://aistudio.google.com/api-keys)
GEMINI_API_KEY=your_api_key_here

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash

# CORS allowed origins (comma-separated). Leave empty to allow all.
CORS_ORIGINS=
