PORT=8000

# Postgres connection string
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/HDT

# Google Gemini API key (https://aistudio.google.com/api-keys)
GEMINI_API_KEY=your_api_key_here

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash

# CORS allowed origins (comma-separated). Leave empty to allow all.
CORS_ORIGINS=
